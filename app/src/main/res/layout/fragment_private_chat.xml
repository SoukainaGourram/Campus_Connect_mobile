<?xml version="1.0" encoding="utf-8"?>

<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <!-- ═══ ÉTAT 1 : Liste des professeurs ═══ -->
    <LinearLayout
        android:id="@+id/layoutProfList"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="visible">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Contacter un professeur"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:padding="16dp"
            android:background="#FFFFFF" />

        <!-- Liste des profs cliquables -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerProfessors"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp" />

    </LinearLayout>

    <!-- ═══ ÉTAT 2 : Conversation privée ═══ -->
    <LinearLayout
        android:id="@+id/layoutPrivateChat"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Barre du haut avec nom du prof + bouton retour -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="#1565C0"
            android:gravity="center_vertical"
            android:padding="8dp">

            <ImageButton
                android:id="@+id/btnBackToList"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#FFFFFF" />

            <TextView
                android:id="@+id/tvChatWithName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Prof..."
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Messages privés -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerPrivateChat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp"
            android:background="#ECE5DD" />

        <!-- Barre d'envoi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etPrivateMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Message privé..."
                android:background="@android:color/white"
                android:padding="12dp"
                android:maxLines="3"
                android:inputType="textMultiLine" />

            <ImageButton
                android:id="@+id/btnSendPrivate"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/ic_menu_send"
                android:background="#1565C0"
                android:padding="10dp" />

        </LinearLayout>
    </LinearLayout>

</FrameLayout>